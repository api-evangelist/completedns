          "name": "Get nameserver history for a domain",
          "request": {
            "name": "Get nameserver history for a domain",
            "description": {
              "content": "Returns the full history of nameserver changes and drop events for the requested domain. Response includes drop count, change count, years tracked, TLD support flag, and a chronologically ordered list of events.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "ns-history",
                ":domain"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "key",
                  "value": "<string>",
                  "description": "(Required) API key issued in the CompleteDNS account API section."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "domain",
                  "description": "(Required) The fully qualified domain to look up."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
