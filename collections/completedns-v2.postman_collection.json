      "item": [
        {
          "id": "d830d124-b002-40b4-9cd4-57951f802dbe",
          "name": "Get DNS history for a domain",
          "request": {
            "name": "Get DNS history for a domain",
            "description": {
              "content": "Returns the full history of nameserver changes and drop events for the requested domain, including the count of changes, count of drops, years tracked, and a chronologically ordered list of events.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "dns-history",
                ":domain"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "key",
                  "value": "<string>",
                  "description": "(Required) API key issued in the CompleteDNS account API section."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "domain",
                  "description": "(Required) The fully qualified domain to look up."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
