  "info": {
    "_postman_id": "e5dc286b-567f-4fc2-8ffb-5ab17a88e951",
    "name": "CompleteDNS API v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The CompleteDNS API v2 returns the historical nameserver record for a domain. The service tracks nameserver changes and domain drops for over twenty years and returns the chronological list of events for a queried domain. Authentication is via an API key passed as a query string parameter.\n\nContact Support:\n Name: CompleteDNS",
      "type": "text/plain"
    }
